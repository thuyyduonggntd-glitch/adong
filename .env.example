# 서버리스(Netlify Functions/Vercel) 환경에서는 Neon의 pooled(-pooler) 엔드포인트를 쓰고,
# pgbouncer=true로 PgBouncer 트랜잭션 풀링과 호환시킨다. 인스턴스당 커넥션은 1개로 제한.
DATABASE_URL="postgresql://postgres:password@ep-xxxx-pooler.region.aws.neon.tech/kkumbb_shop?sslmode=require&channel_binding=require&pgbouncer=true&connection_limit=1&pool_timeout=10"
NEXTAUTH_SECRET="your-secret-key-change-this"
NEXTAUTH_URL="http://localhost:3000"
# Google Cloud Translation API v2 — https://console.cloud.google.com 에서 발급
GOOGLE_TRANSLATE_API_KEY="your-google-translate-api-key"

# 상품 이미지 업로드용 Google Cloud Storage
GCS_PROJECT_ID="project-79c92a60-b909-49e6-b0c"
GCS_BUCKET="kkumbb-images"
# GCP 콘솔에서 발급한 서비스 계정 키(JSON) 전체를 한 줄로 붙여넣기
GOOGLE_CLOUD_CREDENTIALS='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# true로 켜면 Prisma가 쿼리별 실제 소요시간(ms)을 로그로 남긴다 (응답속도 진단용, 평소엔 꺼둘 것)
DEBUG_PRISMA_QUERIES="false"
