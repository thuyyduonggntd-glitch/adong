generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUB_ADMIN
}

enum DealerGrade {
  REGULAR
  SILVER
  GOLD
  VIP
}

enum SaleType {
  RATE
  AMOUNT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  DELIVERED
  CANCELLED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
}

enum QnAStatus {
  PENDING
  ANSWERED
  CLOSED
}

enum NoticeType {
  MANUAL
  SALE
  CARRYOVER
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  password       String
  name           String
  phone          String?
  address        String?
  shippingName   String?
  shippingPhone  String?
  shopName       String?
  businessNumber String?
  shopSiteUrl    String?
  country        String?
  role           Role             @default(USER)
  dealerGrade    DealerGrade      @default(REGULAR)
  isActive       Boolean          @default(true)
  depositAmount  Float            @default(0)
  orders         Order[]
  cart           CartItem[]
  wishlist       Wishlist[]
  favoriteBrands FavoriteBrand[]
  reviews        Review[]
  transactions   Transaction[]
  qna            QnA[]
  shipping       Shipping[]
  inbounds       Inbound[]
  noticeSeens    NoticeSeen[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Category {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  name_en      String?
  name_vi      String?
  name_th      String?
  name_ru      String?
  name_mn      String?
  name_es      String?
  translatedAt DateTime?
  products     Product[]
  sizeProducts Product[] @relation("ProductSizeCategory")
}

model Product {
  id             String           @id @default(cuid())
  name           String
  description    String           @db.Text
  price          Int
  images         String[]
  brand          String?
  productNumber  String?
  material       String?
  gender         String?
  productType    String?
  wholesalePrice Int?
  season         String?

  // 자동 번역 필드 (Google Cloud Translation API) — 없으면 한국어 원본으로 폴백
  name_en        String?
  name_vi        String?
  name_th        String?
  name_ru        String?
  name_mn        String?
  name_es        String?
  description_en String?  @db.Text
  description_vi String?  @db.Text
  description_th String?  @db.Text
  description_ru String?  @db.Text
  description_mn String?  @db.Text
  description_es String?  @db.Text
  material_en    String?
  material_vi    String?
  material_th    String?
  material_ru    String?
  material_mn    String?
  material_es    String?
  gender_en      String?
  gender_vi      String?
  gender_th      String?
  gender_ru      String?
  gender_mn      String?
  gender_es      String?
  season_en      String?
  season_vi      String?
  season_th      String?
  season_ru      String?
  season_mn      String?
  season_es      String?
  colors_en      String[]
  colors_vi      String[]
  colors_th      String[]
  colors_ru      String[]
  colors_mn      String[]
  colors_es      String[]
  translatedAt   DateTime?
  sizeImages      String[]
  sizeExtraPrices Json?
  isOnSale    Boolean   @default(false)
  isCarryOver Boolean   @default(false)
  saleType  SaleType?
  saleValue Int?
  prices    ProductPrice[]
  categoryId     String?
  category       Category?        @relation(fields: [categoryId], references: [id])
  sizeCategoryId String?
  sizeCategory   Category?        @relation("ProductSizeCategory", fields: [sizeCategoryId], references: [id])
  sizes          String[]
  colors         String[]
  stock          Int              @default(0)
  remark         String?
  isActive       Boolean          @default(true)
  cancelLocked   Boolean          @default(false)
  orderItems     OrderItem[]
  cartItems      CartItem[]
  wishlist       Wishlist[]
  reviews        Review[]
  inboundItems   InboundItem[]
  variants       ProductVariant[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([categoryId])
  @@index([sizeCategoryId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  color     String
  size      String
  stock     Int     @default(0)

  @@unique([productId, color, size])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  totalAmount     Int
  status          OrderStatus @default(PENDING)
  cancelLocked    Boolean     @default(false)
  note            String?
  shippingName    String?
  shippingPhone   String?
  shippingAddress String?
  shipping        Shipping?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model OrderItem {
  id           String    @id @default(cuid())
  orderId      String
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product   @relation(fields: [productId], references: [id])
  quantity     Int
  price        Int
  size         String
  color        String
  confirmedAt             DateTime?
  arrivedAt               DateTime?
  cancelledAt             DateTime?
  cancelledByAdmin        Boolean   @default(false)
  outOfStockAt            DateTime?
  unshippedAt             DateTime?
  deliveryRequestedAt     DateTime?
  remark                  String?
  cancelLocked            Boolean   @default(false)
  stockSnapshot           Int?
  isOnSale                Boolean   @default(false)
  saleType                SaleType?
  saleValue               Int?

  @@index([orderId])
  @@index([productId])
  @@index([arrivedAt])
  @@index([outOfStockAt])
  @@index([unshippedAt])
  @@index([cancelledAt])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  size      String
  color     String
  createdAt DateTime @default(now())
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  rating    Int
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType
  amount      Int
  description String?
  note        String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())

  @@index([userId])
  @@index([date])
  @@index([type])
}

model Shipping {
  id             String    @id @default(cuid())
  orderId        String    @unique
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  trackingNumber String?
  carrier        String?
  note           String?
  shippedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model QnA {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  title      String
  content    String    @db.Text
  images     String[]
  status     QnAStatus @default(PENDING)
  answer     String?   @db.Text
  answeredAt DateTime?
  answerSeen Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  image       String?
  notice      String?  @db.Text
  sizeInfo    String?  @db.Text
  sizeImages  String[]
  modelInfo   String?  @db.Text
  modelImages String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FavoriteBrand {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandName String
  createdAt DateTime @default(now())

  @@unique([userId, brandName])
}

model CancelPolicy {
  id            String   @id @default(cuid())
  globalEnabled Boolean  @default(false)
  timeLimit     Int?
  cancelFrom    String?  // "HH:MM" KST
  cancelTo      String?  // "HH:MM" KST
  updatedAt     DateTime @updatedAt
}

model DeliveryPolicy {
  id        String   @id @default(cuid())
  fromTime  String?  // "HH:MM" KST
  toTime    String?  // "HH:MM" KST
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model ProductPrice {
  id        String      @id @default(cuid())
  productId String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  grade     DealerGrade
  price     Int

  @@unique([productId, grade])
}

model Inbound {
  id        String        @id @default(cuid())
  brand     String
  note      String?
  arrivedAt DateTime      @default(now())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  items     InboundItem[]
  createdAt DateTime      @default(now())
}

model Notice {
  id        String     @id @default(cuid())
  type      NoticeType @default(MANUAL)
  title     String
  content   String     @db.Text
  isActive  Boolean    @default(true)
  brandName String?
  itemCount Int        @default(1)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // 수동 공지(MANUAL) 자동 번역 필드 (Google Cloud Translation API) — 없으면 한국어 원본으로 폴백
  title_en        String?
  title_vi        String?
  title_th        String?
  title_ru        String?
  title_mn        String?
  title_es        String?
  content_en      String?  @db.Text
  content_vi      String?  @db.Text
  content_th      String?  @db.Text
  content_ru      String?  @db.Text
  content_mn      String?  @db.Text
  content_es      String?  @db.Text
  translatedAt    DateTime?

  seenBy          NoticeSeen[]
}

model NoticeSeen {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  noticeId String
  notice   Notice   @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  seenAt   DateTime @default(now())

  @@unique([userId, noticeId])
}

model InboundItem {
  id        String    @id @default(cuid())
  inboundId String
  inbound   Inbound   @relation(fields: [inboundId], references: [id], onDelete: Cascade)
  productId           String?
  product             Product?  @relation(fields: [productId], references: [id])
  name                String
  quantity            Int
  size                String?
  color               String?
  price               Int?
  shippedAt           DateTime?
  deliveryRequestedAt DateTime?
  isOnSale            Boolean   @default(false)
  saleType            SaleType?
  saleValue           Int?
}
