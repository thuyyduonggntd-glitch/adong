generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum DealerGrade {
  REGULAR
  SILVER
  GOLD
  VIP
}

enum SaleType {
  RATE
  AMOUNT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  DELIVERED
  CANCELLED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
}

enum QnAStatus {
  PENDING
  ANSWERED
  CLOSED
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  password       String
  name           String
  phone          String?
  address        String?
  shippingName   String?
  shippingPhone  String?
  shopName       String?
  businessNumber String?
  role           Role          @default(USER)
  dealerGrade    DealerGrade   @default(REGULAR)
  isActive       Boolean       @default(true)
  depositAmount  Float         @default(0)
  orders         Order[]
  cart           CartItem[]
  wishlist       Wishlist[]
  reviews        Review[]
  transactions   Transaction[]
  qna            QnA[]
  shipping       Shipping[]
  inbounds       Inbound[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  products Product[]
}

model Product {
  id             String           @id @default(cuid())
  name           String
  description    String           @db.Text
  price          Int
  images         String[]
  brand          String?
  productNumber  String?
  material       String?
  gender         String?
  productType    String?
  wholesalePrice Int?
  season         String?
  sizeImages     String[]
  isOnSale  Boolean   @default(false)
  saleType  SaleType?
  saleValue Int?
  prices    ProductPrice[]
  categoryId     String
  category       Category         @relation(fields: [categoryId], references: [id])
  sizes          String[]
  colors         String[]
  stock          Int              @default(0)
  remark         String?
  isActive       Boolean          @default(true)
  cancelLocked   Boolean          @default(false)
  orderItems     OrderItem[]
  cartItems      CartItem[]
  wishlist       Wishlist[]
  reviews        Review[]
  inboundItems   InboundItem[]
  variants       ProductVariant[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  color     String
  size      String
  stock     Int     @default(0)

  @@unique([productId, color, size])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  totalAmount     Int
  status          OrderStatus @default(PENDING)
  cancelLocked    Boolean     @default(false)
  note            String?
  shippingName    String?
  shippingPhone   String?
  shippingAddress String?
  shipping        Shipping?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id           String    @id @default(cuid())
  orderId      String
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product   @relation(fields: [productId], references: [id])
  quantity     Int
  price        Int
  size         String
  color        String
  arrivedAt    DateTime?
  cancelledAt  DateTime?
  outOfStockAt DateTime?
  unshippedAt  DateTime?
  remark       String?
  cancelLocked Boolean   @default(false)
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  size      String
  color     String
  createdAt DateTime @default(now())
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  rating    Int
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType
  amount      Int
  description String?
  note        String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
}

model Shipping {
  id             String    @id @default(cuid())
  orderId        String    @unique
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  trackingNumber String?
  carrier        String?
  note           String?
  shippedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model QnA {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  title      String
  content    String    @db.Text
  images     String[]
  status     QnAStatus @default(PENDING)
  answer     String?   @db.Text
  answeredAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  image       String?
  notice      String?  @db.Text
  sizeInfo    String?  @db.Text
  sizeImages  String[]
  modelInfo   String?  @db.Text
  modelImages String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CancelPolicy {
  id            String   @id @default(cuid())
  globalEnabled Boolean  @default(false)
  timeLimit     Int?
  cancelFrom    String?  // "HH:MM" KST
  cancelTo      String?  // "HH:MM" KST
  updatedAt     DateTime @updatedAt
}

model ProductPrice {
  id        String      @id @default(cuid())
  productId String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  grade     DealerGrade
  price     Int

  @@unique([productId, grade])
}

model Inbound {
  id        String        @id @default(cuid())
  brand     String
  note      String?
  arrivedAt DateTime      @default(now())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  items     InboundItem[]
  createdAt DateTime      @default(now())
}

model InboundItem {
  id        String    @id @default(cuid())
  inboundId String
  inbound   Inbound   @relation(fields: [inboundId], references: [id], onDelete: Cascade)
  productId String?
  product   Product?  @relation(fields: [productId], references: [id])
  name      String
  quantity  Int
  size      String?
  color     String?
  shippedAt DateTime?
}
